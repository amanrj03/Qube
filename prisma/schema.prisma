generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Organization (teacher / college / coaching) ───────────────────────────

model Organization {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  logo      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  otpCode      String?
  otpExpiresAt DateTime?

  classes Class[]
  tests   Test[]

  @@map("organizations")
}

// ─── Class ──────────────────────────────────────────────────────────────────

model Class {
  id             String       @id @default(cuid())
  name           String
  organizationId String
  createdAt      DateTime     @default(now())

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  students     Student[]
  testClasses  TestClass[]

  @@map("classes")
}

// ─── Student ────────────────────────────────────────────────────────────────

model Student {
  id             String   @id @default(cuid())
  registrationNo String
  name           String
  phone          String?
  username       String   @unique   // <registrationNo>@examiz.com
  password       String
  profilePic     String?
  gender         String?
  classId        String
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  class        Class         @relation(fields: [classId], references: [id], onDelete: Cascade)
  attempts     TestAttempt[]

  @@unique([registrationNo, organizationId])
  @@map("students")
}

// ─── Test ────────────────────────────────────────────────────────────────────

model Test {
  id                     String   @id @default(cuid())
  name                   String
  duration               Int
  totalMarks             Int      @default(0)
  isLive                 Boolean  @default(false)
  enableGraphicalAnalysis Boolean @default(true)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  isDraft                Boolean  @default(false)
  organizationId         String?
  startTime              DateTime?
  endTime                DateTime?

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  sections     Section[]
  attempts     TestAttempt[]
  testClasses  TestClass[]

  @@map("tests")
}

// ─── TestClass (which classes a test is assigned to) ────────────────────────

model TestClass {
  testId  String
  classId String

  test  Test  @relation(fields: [testId], references: [id], onDelete: Cascade)
  class Class @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@id([testId, classId])
  @@map("test_classes")
}

// ─── Section ────────────────────────────────────────────────────────────────

model Section {
  id            String       @id @default(cuid())
  name          String
  questionType  QuestionType
  isIntegerType Boolean      @default(false)
  order         Int
  testId        String
  questions     Question[]
  test          Test         @relation(fields: [testId], references: [id], onDelete: Cascade)

  @@map("sections")
}

// ─── Question ───────────────────────────────────────────────────────────────

model Question {
  id             String   @id @default(cuid())
  questionNumber Int
  questionImage  String?
  solutionImage  String?
  correctOption  String?
  correctOptions String?
  correctInteger Int?
  marks          Int      @default(4)
  negativeMarks  Int      @default(-1)
  partialMarks3  Int      @default(0)
  partialMarks2  Int      @default(0)
  partialMarks1  Int      @default(0)
  sectionId      String
  answers        Answer[]
  section        Section  @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@map("questions")
}

// ─── TestAttempt ─────────────────────────────────────────────────────────────

model TestAttempt {
  id                String    @id @default(cuid())
  candidateName     String
  candidateImage    String?
  startTime         DateTime  @default(now())
  endTime           DateTime?
  totalMarks        Int       @default(0)
  isCompleted       Boolean   @default(false)
  warningCount      Int       @default(0)
  testId            String
  studentId         String?
  canResume         Boolean   @default(false)
  needsResume       Boolean   @default(false)
  resumeRequestedAt DateTime?

  answers Answer[]
  test    Test     @relation(fields: [testId], references: [id], onDelete: Cascade)
  student Student? @relation(fields: [studentId], references: [id], onDelete: SetNull)

  @@map("test_attempts")
}

// ─── Answer ──────────────────────────────────────────────────────────────────

model Answer {
  id              String       @id @default(cuid())
  selectedOption  String?
  selectedOptions String?
  integerAnswer   Int?
  status          AnswerStatus @default(NOT_VISITED)
  isCorrect       Boolean?
  marksAwarded    Int          @default(0)
  attemptId       String
  questionId      String
  firstVisitTime  DateTime?
  lastVisitTime   DateTime?
  timeSpent       Int          @default(0)
  visitCount      Int          @default(0)

  attempt  TestAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question Question    @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([attemptId, questionId])
  @@map("answers")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum QuestionType {
  SINGLE_CORRECT
  INTEGER
  MULTIPLE_CORRECT
  MATRIX_MATCH
}

enum AnswerStatus {
  NOT_VISITED
  NOT_ANSWERED
  ANSWERED
  MARKED_FOR_REVIEW
}
